# 必需
AI_API_KEY=sk-your-api-key

# 可选（有默认值）
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_STRONG_MODEL=deepseek-chat
AI_CHEAP_MODEL=deepseek-chat

# 数据库
DB_URL=jdbc:mysql://localhost:3306/video_data_analysis?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=123456

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Ollama embedding
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# LangGraph Agent Engine
LANGGRAPH_BASE_URL=http://localhost:8090
